{
  "name": "static-dapp-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "dapp",
    "evm"
  ],
  "engines": {
    "node": "24.11.1"
  },
  "scripts": {
    "compile": "npm run compile -w evm",
    "test:evm": "npm run test -w evm",
    "generate": "npm run generate -w dapp",
    "dev": "npm run dev -w dapp",
    "build": "npm run build -w dapp",
    "typecheck": "npm run typecheck -w dapp",
    "lint": "eslint . && solhint -q 'evm/contracts/**/*.sol'",
    "lint:fix": "eslint . --fix",
    "lint:sol": "solhint 'evm/contracts/**/*.sol'",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ],
    "*.sol": [
      "solhint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "9.29.0",
    "eslint": "9.29.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.20",
    "globals": "16.2.0",
    "husky": "9.1.7",
    "lint-staged": "16.1.2",
    "prettier": "3.5.3",
    "prettier-plugin-solidity": "^2.2.1",
    "solhint": "^6.0.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.34.0"
  }
}
