# Get your project ID from https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id-here

# Contract addresses (update per deployment)
VITE_CONTRACT_ADDRESS=

# IPFS / static hosting (optional — leave blank for traditional hosting)
# Set to "true" to use hash-based routing (/#/about instead of /about)
VITE_HASH_ROUTING=
# Override SIWE domain for shared gateways (e.g., your ENS name or custom domain)
VITE_SIWE_DOMAIN=
